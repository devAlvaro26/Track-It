{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "approve-scripts": "npm approve-scripts esbuild"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^6.0.4",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^1.26.0",
    "motion": "^12.23.24",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.4",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "lucide-react": "^1.26.0",
    "motion": "^12.23.24",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsx": "^4.23.1",
    "vite": "^8.1.5"
  }
}
